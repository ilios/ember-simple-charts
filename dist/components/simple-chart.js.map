import { precompileTemplate } from "@ember/template-compilation";
export default precompileTemplate("<div\n  class=\"simple-chart\"\n  {{on-resize (perform this.calculateSize)}}\n>\n  <this.chartComponent\n    @data={{@data}}\n    @isIcon={{this.isIcon}}\n    @hover={{perform this.handleHover}}\n    @onClick={{perform this.handleClick}}\n    @leave={{perform this.handleLeave}}\n    @isClickable={{this.isClickable}}\n    @containerHeight={{this.height}}\n    @containerWidth={{this.width}}\n  />\n  {{#if this.tooltipTarget}}\n    {{yield\n      (hash\n        tooltip=(component \"simple-chart-tooltip\" target=this.tooltipTarget title=null)\n      )\n    }}\n  {{/if}}\n</div>\n")