import { precompileTemplate } from "@ember/template-compilation";
export default precompileTemplate("{{#in-element this.applicationElement insertBefore=null}}\n  <div class=\"simple-chart-tooltip\" {{did-insert this.setup}}>\n    <div class=\"content\">\n      {{#if @title}}\n        <div class=\"title\">\n          {{@title}}\n        </div>\n      {{/if}}\n      <div class=\"body\">\n        {{yield}}\n      </div>\n    </div>\n  </div>\n{{/in-element}}\n")